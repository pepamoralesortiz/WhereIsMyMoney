# Supabase — copia este archivo a .env.local y rellena los valores reales.
# Project Settings → API en el dashboard de Supabase.

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Usa la "anon" key o la nueva "publishable" key (sb_publishable_...).
# NUNCA pongas aquí la service_role key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-o-publishable-key
